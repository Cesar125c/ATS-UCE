# ─── ATS-UCE Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

APP_ENV=development
APP_VERSION=0.1.0

DATABASE_URL=postgresql+asyncpg://ats_user:password@postgres:5432/ats_uce_db
POSTGRES_USER=ats_user
POSTGRES_PASSWORD=password
POSTGRES_DB=ats_uce_db

CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=

B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=uce-talentpath-cvs
B2_ENDPOINT_URL=
B2_REGION=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

RESEND_API_KEY=
RESEND_FROM_EMAIL=talentpath@uce.edu.ec

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,file://

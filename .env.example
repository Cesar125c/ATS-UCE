# ─── ATS-UCE Platform — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Usage:
#   docker compose up               # development
#   FRONTEND_TARGET=production docker compose up   # QA / production

# ─── General ─────────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0
FRONTEND_TARGET=development           # development | production

# ─── Ports ───────────────────────────────────────────────────────────────────
FRONTEND_PORT=5173
BACKEND_PORT=8000
POSTGRES_PORT=5432
NGINX_PORT=80
NGINX_SSL_PORT=443

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=ats_uce
POSTGRES_PASSWORD=ats_uce_secret
POSTGRES_DB=ats_uce_dev
DATABASE_URL=postgresql+asyncpg://ats_uce:ats_uce_secret@postgres:5432/ats_uce_dev

# ─── Clerk Auth ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# ─── Backblaze B2 ────────────────────────────────────────────────────────────
B2_APPLICATION_KEY_ID=your_b2_key_id
B2_APPLICATION_KEY=your_b2_application_key
B2_BUCKET_NAME=uce-talentpath-cvs
B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ─── Resend (Email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=talentpath@uce.edu.ec

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost","http://localhost:80"]

# ─── SSL (solo production) ───────────────────────────────────────────────────
SSL_CERT_PATH=/etc/ssl/certs/fullchain.pem
SSL_KEY_PATH=/etc/ssl/private/privkey.pem
